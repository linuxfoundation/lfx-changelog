# Database (Prisma)
# Option 1: Individual vars (used by K8s deployment)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lfx_changelog
DB_USER=changelog
DB_PASSWORD=your-password
# Option 2: Full connection string (takes priority if set)
# DATABASE_URL="postgresql://changelog:your-password@localhost:5432/lfx_changelog?schema=public"

# Auth0 OIDC
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_ISSUER_BASE_URL=https://linuxfoundation-dev.auth0.com
AUTH0_SECRET=random-string-minimum-32-characters
BASE_URL=http://localhost:4204

# GitHub App
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-key-here\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# AI (LiteLLM)
LITELLM_API_KEY=your-litellm-api-key
AI_API_URL=https://your-litellm-proxy-url/chat/completions

# OpenSearch (optional — search degrades gracefully when unavailable)
OPENSEARCH_URL=http://localhost:9200

# Datadog (optional — RUM disabled when empty, APM auto-enabled in production)
DD_RUM_CLIENT_ID=
DD_RUM_APPLICATION_ID=

# Slack OAuth (token rotation enabled)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_TOKEN_ENCRYPTION_KEY=      # 32-byte hex key for AES-256-GCM token encryption

# Webhook state signing (used by GitHub App and Slack OAuth callbacks)
WEBHOOK_STATE_SECRET=            # Random secret for HMAC-signing OAuth state params

# Atlassian MCP (optional — Jira/Confluence context for changelog agent)
# Create a personal API token at https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_MCP_EMAIL=
ATLASSIAN_MCP_API_TOKEN=
ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
