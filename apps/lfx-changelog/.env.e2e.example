# E2E Test Environment
# Copy to .env.e2e and fill in values

# Test database (postgres-test service on port 5433)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=lfx_changelog_test
DB_USER=changelog
DB_PASSWORD=changelog_dev

# OpenSearch test instance (opensearch-test service on port 9202)
OPENSEARCH_URL=http://localhost:9202

# Skip rate limiting during E2E tests
SKIP_RATE_LIMIT=true

# Atlassian / Jira (required for roadmap tests)
ATLASSIAN_EMAIL=
ATLASSIAN_API_KEY=
ATLASSIAN_CLOUD_ID=

# Slack OAuth (required for Slack integration tests)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_TOKEN_ENCRYPTION_KEY=
WEBHOOK_STATE_SECRET=

# Auth0 test user credentials
E2E_SUPER_ADMIN_USERNAME=
E2E_SUPER_ADMIN_PASSWORD=
E2E_PRODUCT_ADMIN_USERNAME=
E2E_PRODUCT_ADMIN_PASSWORD=
E2E_EDITOR_USERNAME=
E2E_EDITOR_PASSWORD=
E2E_USER_USERNAME=
E2E_USER_PASSWORD=
