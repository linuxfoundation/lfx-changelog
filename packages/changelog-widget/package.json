{
  "name": "@linuxfoundation/lfx-changelog",
  "version": "0.1.0",
  "description": "Embeddable changelog widget for LFX products — works with Angular, Vue, React, and plain HTML",
  "license": "MIT",
  "author": "The Linux Foundation",
  "type": "module",
  "main": "./dist/lfx-changelog.umd.cjs",
  "module": "./dist/lfx-changelog.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lfx-changelog.es.js",
      "require": "./dist/lfx-changelog.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "changelog",
    "widget",
    "web-component",
    "lfx",
    "linux-foundation"
  ],
  "sideEffects": true,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "build:development": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "build:production": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "build:staging": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "lint": "echo 'No linter configured yet'"
  },
  "dependencies": {
    "dompurify": "^3.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "vite": "^6.3.0"
  }
}
